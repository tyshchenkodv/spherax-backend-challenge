# Environment Variables Example
# Copy this to .env and adjust values as needed

# Node environment
NODE_ENV=development

# IAM Service Configuration
SERVICE_NAME=iam-service
IAM_HTTP_PORT=3001
IAM_GRPC_URL=0.0.0.0:50051

# Notify Service Configuration
# (when running notify-service separately)
# SERVICE_NAME=notify-service
NOTIFY_HTTP_PORT=3002
NOTIFY_GRPC_URL=0.0.0.0:50052
IAM_GRPC_CLIENT_URL=localhost:50051
