{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "apps/iam-service",
  "sourceRoot": "apps/iam-service/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "tsconfig.build.json"
  },
  "projects": {
    "iam-service": {
      "type": "application",
      "root": "apps/iam-service",
      "entryFile": "main",
      "sourceRoot": "apps/iam-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/iam-service/tsconfig.app.json"
      }
    },
    "notify-service": {
      "type": "application",
      "root": "apps/notify-service",
      "entryFile": "main",
      "sourceRoot": "apps/notify-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notify-service/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "src/index"
    },
    "config": {
      "type": "library",
      "root": "libs/config",
      "entryFile": "src/index"
    },
    "api-versioning": {
      "type": "library",
      "root": "libs/api-versioning",
      "entryFile": "src/index"
    },
    "grpc": {
      "type": "library",
      "root": "libs/grpc",
      "entryFile": "src/index"
    },
    "proto": {
      "type": "library",
      "root": "libs/proto",
      "entryFile": "src/index"
    }
  }
}
